{
    "name": "quan-ly-thiet-bi",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Hệ thống Quản lý Thiết bị - Asset Management System (cloned from source workspace)",
    "scripts": {
        "dev": "node scripts/check-install.mjs && pnpm --filter @qltb/api dev",
        "dev:web": "node scripts/check-install.mjs && pnpm --filter @qltb/web-ui dev",
        "dev:packages": "pnpm --filter './packages/**' dev",
        "dev:all": "node scripts/check-install.mjs && concurrently -n \"pkgs,api,web\" -c \"cyan,green,blue\" --kill-others-on-fail \"pnpm dev:packages\" \"pnpm --filter @qltb/api dev\" \"pnpm --filter @qltb/web-ui dev\"",
        "dev:infra": "docker-compose -f docker-compose.dev.yml up -d",
        "dev:stop": "pnpm exec kill-port 3000",
        "dev:web:stop": "pnpm exec kill-port 5173",
        "dev:infra:stop": "docker-compose -f docker-compose.dev.yml down",
        "dev:start:all": "pnpm dev:infra && pnpm dev:all",
        "dev:stop:all": "pnpm dev:web:stop && pnpm dev:stop && pnpm dev:infra:stop",
        "preview": "pnpm --filter @qltb/web-ui preview",
        "build": "pnpm -r build",
        "build:prod": "pnpm --filter @qltb/api build:prod && pnpm --filter @qltb/web-ui build:prod",
        "build:api": "pnpm --filter @qltb/api build",
        "build:web": "pnpm --filter @qltb/web-ui build",
        "deploy": "bash scripts/deploy.sh",
        "deploy:migrate": "bash scripts/deploy.sh --migrate",
        "deploy:update": "bash scripts/deploy.sh --migrate --restart",
        "deploy:fresh": "bash scripts/deploy.sh --migrate --seed --clean --setup-https",
        "deploy:init": "bash scripts/deploy.sh --migrate --seed --clean --setup-https && sudo bash scripts/setup-service.sh",
        "deploy:docker": "docker-compose -f docker-compose.app.yml up -d --build",
        "service:setup": "sudo bash scripts/setup-service.sh",
        "service:restart": "sudo bash scripts/setup-service.sh --restart",
        "service:remove": "sudo bash scripts/setup-service.sh --remove",
        "test": "pnpm -r test",
        "test:lint": "pnpm -r lint",
        "test:typecheck": "pnpm -r typecheck",
        "test:build": "pnpm -r build",
        "test:e2e": "playwright test",
        "test:api": "playwright test --project=api",
        "test:ui": "playwright test --project=chromium",
        "test:smoke": "playwright test --grep @smoke",
        "test:headed": "playwright test --headed",
        "test:debug": "playwright test --debug",
        "test:video:guide": "playwright test --config playwright.video.config.ts --project=video-guide --headed --workers=1",
        "test:report": "playwright show-report",
        "test:all": "pnpm test:lint && pnpm test:typecheck && pnpm test && pnpm test:build && pnpm test:up && pnpm test:e2e && pnpm test:down",
        "test:up": "docker compose up -d postgres api web-ui pgadmin",
        "test:reset": "pnpm db:migrate && pnpm db:seed",
        "test:down": "docker compose down -v",
        "test:docker": "docker-compose -f docker-compose.test.yml up --build --abort-on-container-exit",
        "test:docker:clean": "docker-compose -f docker-compose.test.yml down -v",
        "typecheck": "tsc --build",
        "clean": "pnpm -r exec rm -rf node_modules dist",
        "db:empty": "node scripts/db-empty.mjs",
        "db:migrate": "node scripts/db-migrate.mjs",
        "db:seed": "node scripts/db-seed.mjs",
        "db:reset": "pnpm db:empty && pnpm db:migrate && pnpm db:seed",
        "db:setup": "node scripts/db-setup.mjs",
        "setup:status": "node -e \"fetch('http://localhost:3000/api/setup/status').then((r)=>r.text()).then(console.log).catch((e)=>{console.error(e);process.exit(1);})\"",
        "smoke:warehouse:roles": "node scripts/smoke-warehouse-role-access.mjs",
        "generate:docx-templates": "node scripts/generate-docx-templates.mjs",
        "deps:check": "depcruise apps/api/src apps/web-ui/src packages --config .dependency-cruiser.cjs --output-type err-long",
        "deps:json": "depcruise apps/api/src apps/web-ui/src packages --config .dependency-cruiser.cjs --output-type json --output-to artifacts/dependency-cruiser/report.json",
        "deps:html": "depcruise apps/api/src apps/web-ui/src packages --config .dependency-cruiser.cjs --output-type err-html --output-to artifacts/dependency-cruiser/report.html",
        "deps:graph": "depcruise apps/api/src apps/web-ui/src packages --config .dependency-cruiser.cjs --output-type dot --output-to artifacts/dependency-cruiser/graph.dot"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.3.0",
        "@playwright/test": "^1.58.2",
        "concurrently": "^9.0.0",
        "dependency-cruiser": "^17.3.10",
        "docx": "^9.6.1",
        "dotenv": "^17.3.1",
        "kill-port": "^2.0.1",
        "playwright": "^1.58.2",
        "pnpm": "^10.32.1",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.0"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=8.0.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "core-js",
            "es5-ext",
            "msgpackr-extract"
        ],
        "patchedDependencies": {
            "flowbite-svelte@0.46.23": "patches/flowbite-svelte@0.46.23.patch"
        }
    }
}