{
    "name": "@qltb/web-ui",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev --port 5173",
        "build": "svelte-kit sync && vite build",
        "build:prod": "svelte-kit sync && vite build --mode production --minify esbuild",
        "preview": "vite preview",
        "lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.check.json",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.check.json",
        "test": "vitest run",
        "test:e2e": "playwright test"
    },
    "devDependencies": {
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/kit": "^2.55.0",
        "@sveltejs/vite-plugin-svelte": "^4.0.4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/svelte": "^5.3.1",
        "@types/node": "^22.0.0",
        "autoprefixer": "^10.4.27",
        "happy-dom": "^20.8.4",
        "jsdom": "^29.0.0",
        "postcss": "^8.5.8",
        "svelte": "^5.54.0",
        "svelte-check": "^4.4.5",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.9.3",
        "vite": "5.4.21",
        "vitest": "^3.0.0"
    },
    "dependencies": {
        "@qltb/contracts": "workspace:*",
        "@qltb/domain": "workspace:*",
        "@xyflow/svelte": "^1.5.1",
        "@xyflow/system": "^0.0.75",
        "clsx": "^2.1.1",
        "cytoscape": "^3.33.1",
        "echarts": "^6.0.0",
        "flowbite-svelte": "^0.46.23",
        "html2pdf.js": "^0.14.0",
        "intl-messageformat": "^11.1.3",
        "jsqr": "^1.4.0",
        "lucide-svelte": "^0.460.1",
        "mammoth": "^1.12.0",
        "mermaid": "^11.13.0",
        "svelte-i18n": "^4.0.1",
        "tailwind-merge": "^3.5.0",
        "zod": "^3.25.76"
    }
}
