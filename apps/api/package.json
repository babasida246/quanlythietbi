        "@types/pg": "^8.18.0",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.0"
