{
    "name": "@qltb/api",
    "version": "1.0.0",
    "description": "QuanLyThietBi API - Asset Management",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/main.ts",
        "build": "tsup",
        "build:prod": "tsup --minify",
        "start": "node dist/main.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "lint": "echo 'Linting completed - no linter configured'"
    },
    "dependencies": {
        "@fastify/cors": "^10.1.0",
        "@fastify/helmet": "^13.0.2",
        "@fastify/multipart": "^9.4.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.5",
        "@qltb/application": "workspace:*",
        "@qltb/contracts": "workspace:*",
        "@qltb/domain": "workspace:*",
        "@qltb/infra-postgres": "workspace:*",
        "@sinclair/typebox": "^0.34.48",
        "bcryptjs": "^3.0.3",
        "bull": "^4.16.5",
        "docxtemplater": "^3.68.3",
        "dotenv": "^17.3.1",
        "fastify": "~5.7.0",
        "fastify-plugin": "^5.0.1",
        "i18next": "^25.8.18",
        "jsonwebtoken": "^9.0.3",
        "nodemailer": "^6.10.1",
        "pdfkit": "^0.18.0",
        "pg": "^8.20.0",
        "pino-pretty": "^13.0.0",
        "pizzip": "^3.2.0",
