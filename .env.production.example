# ==============================================================================
# .env.production.example — Template cho môi trường Production / Standalone
#
# Dùng khi triển khai từng dịch vụ trên server riêng biệt (không Docker Compose).
# Sao chép file này thành .env và điền thông tin thực tế.
#
# Cách dùng:
#   cp .env.production.example .env
#   # Chỉnh sửa .env với thông tin thực tế
#   node apps/api/dist/apps/api/src/main.js   # hoặc dùng pm2, systemd
# ==============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
WEB_PORT=3001

# -----------------------------------------------------------------------------
# Database — Trỏ đến PostgreSQL server riêng biệt
# Ví dụ: AWS RDS, Azure Database, on-premise PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://qltb_user:CHANGE_ME@db.your-domain.com:5432/qltb
DATABASE_POOL_MAX=20

# -----------------------------------------------------------------------------
# Redis — Trỏ đến Redis server riêng biệt
# Ví dụ: AWS ElastiCache, Redis Cloud, on-premise Redis
# Format: redis://[:PASSWORD@]HOST:PORT  hoặc rediss:// nếu dùng TLS
# -----------------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME@redis.your-domain.com:6379
REDIS_CACHE_ENABLED=true
REDIS_CACHE_TTL=900

# -----------------------------------------------------------------------------
# Migrations on startup
# Để true nếu chạy API lần đầu hoặc sau khi deploy code mới
# Sau khi đã migrate rồi, có thể đặt false để khởi động nhanh hơn
# -----------------------------------------------------------------------------
RUN_MIGRATIONS=true

# -----------------------------------------------------------------------------
# Security — THAY ĐỔI TRƯỚC KHI DEPLOY
# Dùng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# để tạo secret ngẫu nhiên
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=CHANGE_ME_USE_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_ME_USE_DIFFERENT_RANDOM_64_CHAR_STRING
DISABLE_AUTH=false

# -----------------------------------------------------------------------------
# Frontend API base URLs
# Thay bằng domain thực của API server
# QUAN TRỌNG: VITE_ vars được nhúng lúc build, phải đặt đúng trước khi chạy
#   `pnpm build:web` hoặc `docker build`
# -----------------------------------------------------------------------------
VITE_API_BASE=https://api.your-domain.com/api
VITE_API_URL=https://api.your-domain.com/api
BACKEND_BASE_URL=https://api.your-domain.com/api

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=warn

# -----------------------------------------------------------------------------
# Rate limiting — Bật cho production
# -----------------------------------------------------------------------------
ENABLE_RATE_LIMIT=true
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# SMTP (optional — dùng cho tính năng gửi email)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@your-domain.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@your-domain.com

# -----------------------------------------------------------------------------
# File storage
# Đường dẫn tuyệt đối hoặc dùng object storage (S3, MinIO)
# -----------------------------------------------------------------------------
ASSET_UPLOAD_DIR=/var/qltb/uploads

# -----------------------------------------------------------------------------
# HTTPS/TLS — Nginx + Certbot (docker-compose.app.yml)
# -----------------------------------------------------------------------------
# Domain public để cấp cert và phục vụ app
QLTB_DOMAIN=qltb.your-domain.com

# Email nhận thông báo hết hạn cert
LETSENCRYPT_EMAIL=admin@your-domain.com

# Chỉ bật true khi test cấp cert để tránh rate limit production
LETSENCRYPT_STAGING=false

# Chu kỳ renew certbot (giây) — mặc định 12 giờ
CERTBOT_RENEW_INTERVAL_SECONDS=43200
