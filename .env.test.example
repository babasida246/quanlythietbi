# QuanLyThietBi - E2E Test Environment
# Copy to .env.test and adjust values for your machine/CI.

# -----------------------------------------------------------------------------
# Base URLs for tests
# -----------------------------------------------------------------------------
# Use http://localhost:3001 for docker-compose local stack.
# If you run web-ui with `pnpm --filter @qltb/web-ui dev`, set WEB_BASE_URL to 5173.
WEB_BASE_URL=http://localhost:3001
API_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Test user credentials
# -----------------------------------------------------------------------------
TEST_USER_EMAIL=admin@test.com
TEST_USER_PASSWORD=admin123

# -----------------------------------------------------------------------------
# API endpoint prefix detection: auto | /api/v1 | /v1 | /api | (empty)
# -----------------------------------------------------------------------------
API_PATH_PREFIX=auto

# -----------------------------------------------------------------------------
# Test behavior
# -----------------------------------------------------------------------------
E2E_MOCK_AUTH=false

# -----------------------------------------------------------------------------
# Timeouts (milliseconds)
# -----------------------------------------------------------------------------
TEST_TIMEOUT=30000
NAVIGATION_TIMEOUT=15000

# -----------------------------------------------------------------------------
# Optional database for test data setup
# -----------------------------------------------------------------------------
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qltb_test

# -----------------------------------------------------------------------------
# Service health-check retries
# -----------------------------------------------------------------------------
HEALTH_CHECK_RETRIES=10
HEALTH_CHECK_TIMEOUT=5000
