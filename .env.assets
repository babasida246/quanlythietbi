# QuanLyThietBi - Assets Docker Stack Environment
# Used by: docker/compose.assets.yml

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# API / Web host ports
# -----------------------------------------------------------------------------
PORT_API=3100
PORT_WEB=3103

# -----------------------------------------------------------------------------
# Assets database
# -----------------------------------------------------------------------------
ASSETS_DB_HOST=db
ASSETS_DB_PORT=5432
ASSETS_DB_PORT_HOST=5434
ASSETS_DB_NAME=qltb_assets
ASSETS_DB_USER=qltb
ASSETS_DB_PASS=qltb
ASSETS_DATABASE_URL=postgresql://qltb:qltb@db:5432/qltb_assets

# -----------------------------------------------------------------------------
# Startup behavior
# -----------------------------------------------------------------------------
ASSETS_DB_SEED=true
ASSETS_DB_WAIT_TIMEOUT=60

# -----------------------------------------------------------------------------
# Web -> API base URLs
# Keep /api prefix to match backend route prefix /api/v1
# -----------------------------------------------------------------------------
BACKEND_BASE_URL=http://qltb_assets_api:3000/api
VITE_API_BASE=http://qltb_assets_api:3000/api
VITE_API_URL=http://qltb_assets_api:3000/api

# -----------------------------------------------------------------------------
# pgAdmin
# -----------------------------------------------------------------------------
PGADMIN_PORT=5054
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
