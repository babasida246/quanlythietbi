{
    "name": "@qltb/domain",
    "version": "1.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "dev": "tsup src/index.ts --format esm --dts --watch",
        "test": "vitest run",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.0"
    }
}
