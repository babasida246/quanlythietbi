{
    "name": "@qltb/contracts",
    "version": "1.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./checkout": {
            "import": "./dist/checkout/index.js",
            "types": "./dist/checkout/index.d.ts"
        },
        "./components": {
            "import": "./dist/components/index.js",
            "types": "./dist/components/index.d.ts"
        },
        "./consumables": {
            "import": "./dist/consumables/index.js",
            "types": "./dist/consumables/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "dev": "tsup src/index.ts --format esm --dts --watch",
        "test": "vitest run",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@qltb/domain": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "typescript": "^5.3.0",
        "tsup": "^8.0.0",
        "vitest": "^1.0.0"
    }
}