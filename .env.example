# QuanLyThietBi - Development Environment Configuration
# 
# Copy this file to .env and customize values for your environment
# For production deployment, see .env.production.example
#
# Important: VITE_* variables are embedded at BUILD TIME (SPA bundle), 
#            must be set correctly BEFORE running: pnpm build:web

# =============================================================================
# 🖥️  SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
WEB_PORT=3001

# =============================================================================
# 🗄️  DATABASE - PostgreSQL Configuration
# =============================================================================

# ── Connection URL (auto-generated from components below if empty) ─────────
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
# If DATABASE_URL is set, it takes precedence over POSTGRES_* variables
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qltb

# ── PostgreSQL Server Details (used when DATABASE_URL is empty) ───────────
# Hostname/IP of PostgreSQL server
# - localhost, 127.0.0.1: Local machine (default)
# - postgres, db: Docker service name (when using docker-compose)
# - 192.168.1.100, db.example.com: Remote server IP/domain
POSTGRES_HOST=localhost

# PostgreSQL port (default 5432)
POSTGRES_PORT=5432

# PostgreSQL database name
POSTGRES_DB=qltb

# PostgreSQL username (default postgres)
POSTGRES_USER=postgres

# PostgreSQL password (CHANGE BEFORE PRODUCTION!)
POSTGRES_PASSWORD=postgres

# Database connection pool size (max concurrent connections from app to DB)
# Increase if experiencing "too many connections" errors under load
DATABASE_POOL_MAX=10

# =============================================================================
# 🔴 REDIS Cache - Background Jobs, Session, Lock Management
# =============================================================================

# ── Connection URL (auto-generated from components below if empty) ─────────
# Format: redis://[:PASSWORD@]HOST:PORT
# Format: rediss://[:PASSWORD@]HOST:PORT (with TLS)
# If REDIS_URL is set, it takes precedence over REDIS_* variables
REDIS_URL=redis://localhost:6379

# ── Redis Server Details (used when REDIS_URL is empty) ─────────────────
# Hostname/IP of Redis server
# - localhost, 127.0.0.1: Local machine (default)
# - redis, cache: Docker service name (when using docker-compose)
# - 192.168.1.100, cache.example.com: Remote server IP/domain
REDIS_HOST=localhost

# Redis port (default 6379)
REDIS_PORT=6379

# Redis password (if server requires authentication, leave empty if not)
# Most Redis instances don't require this unless specifically configured
REDIS_PASSWORD=

# Redis username (rarely used, only for Redis 6.0+ with ACL enabled)
# REDIS_USERNAME=default

# ── Redis Cache Settings ──────────────────────────────────────────────────
# Enable/disable caching
REDIS_CACHE_ENABLED=true

# Cache TTL (Time To Live) in seconds
# 900 = 15 minutes (recommended for development)
# 3600 = 1 hour (recommended for production)
REDIS_CACHE_TTL=900

# =============================================================================
# 🔐 SECURITY & AUTHENTICATION - JWT Tokens
# =============================================================================

# Access Token Secret (CHANGE BEFORE PRODUCTION!)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=dev-access-secret-key

# Refresh Token Secret (MUST be different from ACCESS_SECRET, CHANGE BEFORE PRODUCTION!)
JWT_REFRESH_SECRET=dev-refresh-secret-key

# Disable authentication globally (TESTING ONLY - never enable in production!)
# When true, backend bypasses JWT validation on /api/v1/* routes
DISABLE_AUTH=false

# =============================================================================
# 📤 FILE STORAGE - Asset Uploads (Images, Documents)
# =============================================================================

# Directory to store uploaded file assets
# - ./uploads: Relative path (creates in project directory)
# - /var/qltb/uploads: Absolute path (typical for Docker/production)
# - /mnt/storage/qltb: NAS/network storage path
ASSET_UPLOAD_DIR=./uploads

# =============================================================================
# 📧 SMTP - Email Configuration (optional, used for reports and notifications)
# =============================================================================

# SMTP server hostname
# Examples: smtp.gmail.com, smtp.outlook.com, mail.example.com, localhost
SMTP_HOST=localhost

# SMTP server port
# 25: Standard unencrypted (rarely used)
# 465: Implicit TLS (SSL)
# 587: Explicit TLS (STARTTLS, recommended)
SMTP_PORT=587

# Use TLS encryption for SMTP
# false = STARTTLS on port 587 (recommended)
# true = Implicit TLS on port 465
SMTP_SECURE=false

# SMTP authentication username (usually full email address or username)
SMTP_USER=

# SMTP authentication password
SMTP_PASS=

# From email address (sender) for outgoing emails
SMTP_FROM=noreply@qltb.local

# =============================================================================
# 🌐 FRONTEND Configuration - API Connections & URLs
# =============================================================================

# API base URL from browser/client-side
# Used by: SPA (Single-Page App) JavaScript
# - http://localhost:3000/api: Local development
# - https://api.example.com/api: Production (must include /api prefix to match route)
# ATTENTION: This value is EMBEDDED in the built SPA, change requires rebuild!
VITE_API_BASE=http://localhost:3000/api

# Alternative API URL (usually same as VITE_API_BASE)
VITE_API_URL=http://localhost:3000/api

# Backend base URL for server-side SvelteKit fetches
# - http://localhost:3000/api: Local (or use Docker service name "api")
# - https://api.example.com/api: Production
BACKEND_BASE_URL=http://localhost:3000/api

# Disable frontend authentication (matches DISABLE_AUTH backend setting)
# - false: Show login page (default, normal operation)
# - true: Skip login, direct access to app (development/testing only!)
VITE_DISABLE_AUTH=false

# =============================================================================
# 📊 LOGGING & DEBUG - Log Level Configuration
# =============================================================================

# Pino logger level (controls verbosity)
# - debug: Very detailed, all debug logs (noisy, dev only)
# - info: Standard information, important milestones (recommended for dev)
# - warn: Only warnings and errors
# - error: Only errors
# - fatal: Only critical errors that cause crash
LOG_LEVEL=info

# =============================================================================
# 🛡️  RATE LIMITING - API Protection Against Abuse
# =============================================================================

# Enable rate limiting (protect against DDoS, brute-force)
# - false: No rate limit (development/testing)
# - true: Enabled (production recommended)
ENABLE_RATE_LIMIT=false

# Maximum requests allowed per time window
# Examples: 100, 10000, 100000
RATE_LIMIT_MAX=10000

# Time window in milliseconds
# 60000 = 1 minute
# 3600000 = 1 hour
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# 🥅 DATABASE MIGRATION - Auto-run Schema Updates
# =============================================================================

# Run database migrations automatically on API startup
# - true: Auto-migrate (recommended for first run and CI/CD)
# - false: Manual migration via `pnpm db:migrate` (faster startup after first run)
RUN_MIGRATIONS=true

# =============================================================================
# 🖱️  MANAGEMENT TOOLS - pgAdmin & Redis Insight (Docker development only)
# These tools run in separate containers and provide web UI management
# =============================================================================

# =============================================================================
# 🔒 TLS/HTTPS (Docker app deployment with Nginx + Certbot)
# =============================================================================

# Public domain served by nginx/certbot (example: qltb.example.com)
QLTB_DOMAIN=localhost

# Email for Let's Encrypt registration and expiry notices
LETSENCRYPT_EMAIL=

# true = use Let's Encrypt staging CA (for testing, avoid rate limits)
LETSENCRYPT_STAGING=true

# Certbot renew interval in seconds (default 12 hours)
CERTBOT_RENEW_INTERVAL_SECONDS=43200

# pgAdmin - PostgreSQL Web Management UI
# Access at: http://localhost:8080

# pgAdmin login email
PGADMIN_EMAIL=admin@example.com

# pgAdmin login password
PGADMIN_PASSWORD=admin

# pgAdmin web interface port
PGADMIN_PORT=8080

# Redis Insight - Redis Web Management UI
# Access at: http://localhost:8001
REDIS_INSIGHT_PORT=8001

# =============================================================================
# 📝 CONFIGURATION QUICK REFERENCE
# =============================================================================
#
# LOCAL DEVELOPMENT:
#   1. cp .env.example .env
#   2. Edit if using remote PostgreSQL/Redis:
#      - Set POSTGRES_HOST, POSTGRES_PORT, POSTGRES_USER, POSTGRES_PASSWORD
#      - Set REDIS_HOST, REDIS_PORT, REDIS_PASSWORD
#   3. pnpm install && pnpm dev
#
# DOCKER COMPOSE DEVELOPMENT:
#   1. Keep POSTGRES_HOST=postgres, REDIS_HOST=redis (Docker service names)
#   2. docker-compose -f docker-compose.dev.yml up
#
# DOCKER COMPOSE APP (PostgreSQL+Redis on remote servers):
#   1. cp .env.production.example .env
#   2. Set DATABASE_URL to remote PostgreSQL
#   3. Set REDIS_URL to remote Redis
#   4. Set VITE_API_BASE to production domain
#   5. Generate new JWT secrets
#   6. docker-compose -f docker-compose.app.yml up -d
#
# PRODUCTION STANDALONE (no Docker):
#   1. cp .env.production.example .env
#   2. Configure all connection strings for production servers
#   3. pnpm build:product
#   4. NODE_ENV=production node apps/api/dist/main.js &
#   5. NODE_ENV=production node apps/web-ui/build/index.js &
#
# =============================================================================
