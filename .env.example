# QuanLyThietBi - Development Environment
# Copy to .env (and optionally override in .env.local)

# -----------------------------------------------------------------------------
# Server (required by apps/api/src/config/env.ts)
# -----------------------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qltb
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# Security / Auth (optional, fallback values exist in code)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=dev-access-secret-key
JWT_REFRESH_SECRET=dev-refresh-secret-key

# -----------------------------------------------------------------------------
# File storage (optional)
# -----------------------------------------------------------------------------
ASSET_UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# Background services (optional)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# SMTP (optional, used by report email features)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@qltb.local

# -----------------------------------------------------------------------------
# Frontend API base URLs
# Keep /api prefix to match backend route prefix /api/v1
# -----------------------------------------------------------------------------
VITE_API_BASE=http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api
BACKEND_BASE_URL=http://localhost:3000/api

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
ENABLE_RATE_LIMIT=false
RATE_LIMIT_MAX=10000
RATE_LIMIT_WINDOW_MS=60000
