# QuanLyThietBi - Development Environment
# Copy to .env (and optionally override in .env.local)
# Xem .env.production.example để biết template cho môi trường production/standalone

# -----------------------------------------------------------------------------
# Server (required by apps/api/src/config/env.ts)
# -----------------------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
WEB_PORT=3001

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qltb
DATABASE_POOL_MAX=10

# ── Biến dùng bởi docker-compose.yml để khởi tạo container PostgreSQL ──────
POSTGRES_DB=qltb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_CACHE_ENABLED=true
REDIS_CACHE_TTL=900

# ── Biến dùng bởi docker-compose.yml để khởi tạo container Redis ───────────
REDIS_PASSWORD=
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Migrations on startup (docker entrypoint)
# Đặt false nếu bạn muốn tự chạy migration thủ công
# -----------------------------------------------------------------------------
RUN_MIGRATIONS=true

# -----------------------------------------------------------------------------
# Security / Auth (optional, fallback values exist in code)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=dev-access-secret-key
JWT_REFRESH_SECRET=dev-refresh-secret-key

# -----------------------------------------------------------------------------
# File storage (optional)
# -----------------------------------------------------------------------------
ASSET_UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# SMTP (optional, used by report email features)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@qltb.local

# -----------------------------------------------------------------------------
# Frontend API base URLs
# Keep /api prefix to match backend route prefix /api/v1
# VITE_ vars được nhúng vào lúc build — cần đặt đúng trước khi build web-ui
# -----------------------------------------------------------------------------
VITE_API_BASE=http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api
BACKEND_BASE_URL=http://localhost:3000/api

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
ENABLE_RATE_LIMIT=false
RATE_LIMIT_MAX=10000
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# pgAdmin (docker-compose.yml và docker-compose.dev.yml)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=8080
REDIS_INSIGHT_PORT=8001
